! =============================================
! Port Configuration - {{ clinic.name }}
! Workstation Port Assignments
! Generated by Clinic Network Automation Tool
! =============================================
!
{% for workstation in workstations %}
interface {{ workstation.port }}
 description {{ workstation.description }}
 switchport mode access
 switchport access vlan {{ workstation.vlan }}
 switchport port-security
 switchport port-security maximum {{ workstation.mac_limit }}
 switchport port-security violation shutdown
 spanning-tree portfast
 no shutdown
!
{% endfor %}
! Shutdown unused ports
{% for port_num in range(3, 25) %}
interface GigabitEthernet0/{{ port_num }}
 description UNUSED - DISABLED
 shutdown
!
{% endfor %}